# AETHER Constellation Manager Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Data Configuration
DATA_DIR=./data
SATELLITE_TLE_FILE=active.txt
DEBRIS_TLE_FILES=debris_iridium.txt,debris_cosmos.txt,debris_fengyun.txt

# Conjunction Detection Parameters
PREDICTION_HORIZON_SECONDS=86400.0
MISS_DISTANCE_ALERT_THRESHOLD_M=100.0
SPATIAL_SCREENING_THRESHOLD_KM=50.0
TEMPORAL_SCREENING_THRESHOLD_KM=25.0
COARSE_PROPAGATION_STEP_SECONDS=300.0
FINE_PROPAGATION_STEP_SECONDS=10.0

# Maneuver Constraints
MAX_DELTA_V_MS=15.0
COOLDOWN_SECONDS=600.0
COMMAND_LATENCY_SECONDS=10.0
LOS_CRITICAL_TCA_THRESHOLD_S=1800.0

# Fuel Parameters
DEFAULT_FUEL_MASS_KG=50.0
DEFAULT_DRY_MASS_KG=500.0
DEFAULT_ISP_SECONDS=300.0

# Performance Tuning
CACHE_PROPAGATION_RESULTS=true
CACHE_TTL_SECONDS=60.0
MAX_DEBRIS_IN_SNAPSHOT=10000
